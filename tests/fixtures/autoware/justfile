# Autoware Planning Simulator Test

# Default recipe (show help)
default:
    @just --list

# Variables
script_dir := justfile_directory()
activate_script := script_dir / "activate_autoware.sh"
map_path := env_var_or_default('MAP_PATH', env_var('HOME') / 'autoware_map/sample-map-planning')

# Verify Autoware installation
check-autoware:
    #!/usr/bin/env bash
    set -e
    if [ ! -f "{{activate_script}}" ]; then
        echo "ERROR: activate_autoware.sh not found"
        exit 1
    fi
    source "{{activate_script}}"
    if ! ros2 pkg prefix autoware_launch &>/dev/null; then
        echo "ERROR: autoware_launch package not found"
        echo "Edit activate_autoware.sh to activate your Autoware environment"
        exit 1
    fi

# Run Autoware simulator with play_launch (foreground, Ctrl-C to stop)
run-sim: check-autoware
    #!/usr/bin/env bash
    set -e
    SCRIPT_DIR="{{script_dir}}"
    cd "$SCRIPT_DIR"

    MAP_PATH="{{map_path}}"

    if [ ! -f "$SCRIPT_DIR/cyclonedds.xml" ]; then
        echo "ERROR: CycloneDDS configuration file not found at $SCRIPT_DIR/cyclonedds.xml"
        exit 1
    fi

    # Source ROS and Autoware setup
    source ../../../install/setup.bash
    source activate_autoware.sh
    export CYCLONEDDS_URI="file://$SCRIPT_DIR/cyclonedds.xml"

    # Run with play_launch
    play_launch launch \
        --web-addr 0.0.0.0:8080 \
        autoware_launch planning_simulator.launch.xml \
        map_path:="$MAP_PATH"

# Run Autoware demo (simulator + autonomous test)
run-demo: check-autoware
    #!/usr/bin/env bash
    set -e
    SCRIPT_DIR="{{script_dir}}"
    cd "$SCRIPT_DIR"

    MAP_PATH="{{map_path}}"

    if [ ! -f "$SCRIPT_DIR/cyclonedds.xml" ]; then
        echo "ERROR: CycloneDDS configuration file not found at $SCRIPT_DIR/cyclonedds.xml"
        exit 1
    fi

    # Source ROS, Autoware, and play_launch setup
    source activate_autoware.sh
    source "$SCRIPT_DIR/../../../install/setup.bash"
    export CYCLONEDDS_URI="file://$SCRIPT_DIR/cyclonedds.xml"

    # Start simulator in background
    echo "[Demo] Starting Autoware planning simulator..."
    play_launch launch \
        --web-addr 0.0.0.0:8080 \
        autoware_launch planning_simulator.launch.xml \
        map_path:="$MAP_PATH" &
    SIM_PID=$!
    SIM_PGID=$(ps -o pgid= -p $SIM_PID | tr -d ' ')

    cleanup() {
        echo "[Demo] Shutting down (PGID=$SIM_PGID)..."
        kill -TERM -$SIM_PGID 2>/dev/null || true
        sleep 2
        kill -9 -$SIM_PGID 2>/dev/null || true
    }
    trap cleanup EXIT INT TERM

    echo "[Demo] Waiting 60s for system initialization..."
    sleep 60

    echo "[Demo] Running autonomous driving test..."
    python3 scripts/test_autonomous_drive.py
    echo "[Demo] Test completed. Press Ctrl-C to stop simulator."

    wait $SIM_PID

# Generate resource usage plots from latest play_log
plot:
    @play_launch plot

# Compare Rust and Python parser outputs — SystemModel shape (Phase 47:
# the parser-parity gate runs on the model; record.json is retired).
# Self-contained: resolves both parsers itself.
compare-dumps: check-autoware
    #!/usr/bin/env bash
    set -e
    SCRIPT_DIR="{{script_dir}}"
    cd "$SCRIPT_DIR"
    REPO_ROOT="$SCRIPT_DIR/../../.."

    MAP_PATH="{{map_path}}"

    # Source ROS and Autoware setup
    source "$REPO_ROOT/install/setup.bash"
    source activate_autoware.sh
    # Phase 46.5/47.B1 — put the colcon-built binary and the current
    # worktree's `python/` package ahead of PATH/PYTHONPATH so this never
    # silently exercises a stale pip install (the `--parser python`
    # stale-scope-path guard fails loud on a pre-Phase-40.1 install
    # instead — this just avoids tripping it on a perfectly good repo).
    export PATH="$REPO_ROOT/install/play_launch/lib/play_launch:$PATH"
    export PYTHONPATH="$REPO_ROOT/python:$PYTHONPATH"

    echo "Resolving with Rust parser..."
    play_launch resolve --parser rust -o model_rust.yaml \
        autoware_launch planning_simulator.launch.xml \
        map_path:="$MAP_PATH"

    echo "Resolving with Python parser..."
    play_launch resolve --parser python -o model_python.yaml \
        autoware_launch planning_simulator.launch.xml \
        map_path:="$MAP_PATH"

    echo ""
    echo "Comparing Rust and Python SystemModels..."
    echo ""
    python3 "$REPO_ROOT/scripts/compare_models.py" model_rust.yaml model_python.yaml

    echo ""
    echo "Comparison complete."

# Count running processes vs expected (from the resolved SystemModel)
count-processes PARSER="rust": check-autoware
    #!/usr/bin/env bash
    set -e
    SCRIPT_DIR="{{script_dir}}"
    cd "$SCRIPT_DIR"

    MAP_PATH="{{map_path}}"
    PARSER="{{PARSER}}"

    # Source ROS and Autoware setup
    source ../../../install/setup.bash
    source activate_autoware.sh
    export CYCLONEDDS_URI="file://$SCRIPT_DIR/cyclonedds.xml"

    # Clean previous play_log
    rm -rf play_log/latest 2>/dev/null || true

    # Resolve to get expected counts (Phase 47.B5: model, not record.json)
    echo "Resolving with $PARSER parser to get expected counts..."
    play_launch resolve --parser "$PARSER" -o model_count.yaml \
        autoware_launch planning_simulator.launch.xml \
        map_path:="$MAP_PATH"

    EXPECTED=$(python3 -c "import yaml; m = yaml.safe_load(open('model_count.yaml')) or dict(); nodes = (m.get('structure') or dict()).get('nodes') or dict(); containers = sum(1 for n in nodes.values() if n.get('is_container')); composables = sum(1 for n in nodes.values() if not n.get('is_container') and n.get('plugin')); print(len(nodes) - containers - composables + containers)")
    echo "Expected processes: $EXPECTED"

    # Start play_launch in background
    echo "Starting play_launch with --parser $PARSER..."
    play_launch launch \
        --disable-web-ui \
        --parser "$PARSER" \
        autoware_launch planning_simulator.launch.xml \
        map_path:="$MAP_PATH" &
    PL_PID=$!
    PGID=$(ps -o pgid= -p $PL_PID | tr -d ' ')

    cleanup() {
        echo "Cleaning up (PGID=$PGID)..."
        kill -TERM -$PGID 2>/dev/null || true
        sleep 2
        kill -9 -$PGID 2>/dev/null || true
    }
    trap cleanup EXIT

    # Poll pid files until count stabilizes or timeout (60s)
    PREV_COUNT=0
    STABLE=0
    TIMEOUT=60
    ELAPSED=0
    INTERVAL=2

    echo "Waiting for processes to start (timeout: ${TIMEOUT}s)..."
    while [ $ELAPSED -lt $TIMEOUT ]; do
        sleep $INTERVAL
        ELAPSED=$((ELAPSED + INTERVAL))

        # Count cmdline files (containers don't write pid files, but do write cmdline)
        if [ -d "play_log/latest/node" ]; then
            ACTUAL=$(find play_log/latest/node -name "cmdline" -type f ! -empty 2>/dev/null | wc -l)
        else
            ACTUAL=0
        fi

        echo "  ${ELAPSED}s: $ACTUAL/$EXPECTED processes"

        if [ "$ACTUAL" -eq "$PREV_COUNT" ] && [ "$ACTUAL" -gt 0 ]; then
            STABLE=$((STABLE + 1))
        else
            STABLE=0
        fi
        PREV_COUNT=$ACTUAL

        # Stabilized for 3 consecutive polls
        if [ $STABLE -ge 3 ]; then
            echo "Process count stabilized at $ACTUAL"
            break
        fi

        # Already at expected count — wait one more poll to confirm
        if [ "$ACTUAL" -ge "$EXPECTED" ] && [ $STABLE -ge 1 ]; then
            echo "Reached expected count ($ACTUAL >= $EXPECTED)"
            break
        fi
    done

    echo ""
    set +e
    python3 ../../../scripts/count_processes.py model_count.yaml --play-log-dir play_log/latest
    RESULT=$?
    set -e

    rm -f model_count.yaml
    exit $RESULT

# Count processes using Rust parser
count-processes-rust: (count-processes "rust")

# Count processes using Python parser
count-processes-python: (count-processes "python")

# Kill orphan ROS nodes
kill-orphans:
    @./scripts/kill_orphan_nodes.sh

# Static contract check against the Autoware launch tree (requires Autoware env)
check-contracts contracts_dir=(env_var('HOME') / 'repos/autoware-contract'): check-autoware
    #!/usr/bin/env bash
    set -e
    SCRIPT_DIR="{{script_dir}}"
    cd "$SCRIPT_DIR"

    MAP_PATH="{{map_path}}"

    # Source ROS and Autoware setup
    source ../../../install/setup.bash
    source activate_autoware.sh

    play_launch check --contracts {{contracts_dir}} \
        autoware_launch planning_simulator.launch.xml \
        map_path:="$MAP_PATH"
