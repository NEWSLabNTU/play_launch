<?xml version="1.0"?>
<launch>
  <!-- rt_demo bringup: the runnable example behind docs/guide/rt-scheduling.md.
       Namespaces mirror system.toml's control/perception tiers:
         /perception : sensor_node + perception_container (filter_component)
         /control    : control_node (the FIFO 20 / core 0 node)
       See bringup.contract.yaml (provider sidecar) and system.toml
       (RT tiers + bindings) next to / above this file. -->

  <node pkg="rt_demo" exec="sensor_node" name="sensor_node" namespace="/perception"/>

  <node_container pkg="rclcpp_components" exec="component_container"
                  name="perception_container" namespace="/perception">
    <composable_node pkg="rt_demo" plugin="rt_demo::FilterComponent"
                     name="filter_component" namespace="/perception"/>
  </node_container>

  <node pkg="rt_demo" exec="control_node" name="control_node" namespace="/control"/>
</launch>
