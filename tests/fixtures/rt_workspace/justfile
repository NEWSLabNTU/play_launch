# rt_workspace — RT scheduling example + fixture (Phase 39)
#
# Runnable example behind docs/guide/rt-scheduling.md, and an integration
# fixture exercising the RT apply-layer against real (non-system) nodes.

set shell := ["bash", "-c"]

ros_distro := env_var_or_default('ROS_DISTRO', 'humble')

# Colcon-built play_launch binary (repo install/) — NOT the pip-installed one,
# which may be stale relative to the repo checkout. Same binary
# tests/src/fixtures.rs::play_launch_bin() resolves to.
play_launch := "../../../install/play_launch/lib/play_launch/play_launch"

# Show help
default:
    @just --list

# Build the rt_demo package into this fixture's own install/ tree
build:
    #!/usr/bin/env bash
    set -e
    echo "Building rt_demo..."
    . /opt/ros/{{ros_distro}}/setup.bash
    colcon build --base-paths src --symlink-install

# Compare Rust and Python parser outputs — SystemModel shape (Phase 47:
# the parser-parity gate runs on the model; record.json is retired).
# Self-contained: resolves both parsers itself. Also exercises the
# contracts/scheduling layers — this
# fixture ships both a provider contract sidecar (`launch/bringup.contract.yaml`)
# and platform file (`launch/bringup.system.posix.yaml`), auto-discovered
# by channel resolution with no `--contracts`/`--sched` flag needed.
compare-dumps:
    #!/usr/bin/env bash
    set -e
    . /opt/ros/{{ros_distro}}/setup.bash
    . ../../../install/setup.bash
    . install/setup.bash
    # Phase 46.5/47.B1 — current worktree's `python/` package ahead of
    # PYTHONPATH so `--parser python` never silently runs a stale pip
    # install (the stale-scope-path guard fails loud on that instead).
    export PYTHONPATH="$(cd ../../.. && pwd)/python:$PYTHONPATH"

    echo "Resolving with Rust parser..."
    {{play_launch}} resolve --parser rust -o model_rust.yaml rt_demo bringup.launch.xml

    echo "Resolving with Python parser..."
    {{play_launch}} resolve --parser python -o model_python.yaml rt_demo bringup.launch.xml

    echo "Comparing Rust and Python SystemModels..."
    python3 ../../../scripts/compare_models.py model_rust.yaml model_python.yaml
    echo "Comparison complete."

# Validate contracts + scheduling: v2 channel resolution/--explain/overlay,
# the vocabulary-v2 `points_to_cmd` chain, and the legacy system.toml bridge
# (kept as the living bridge test).
check:
    #!/usr/bin/env bash
    set -e
    . /opt/ros/{{ros_distro}}/setup.bash
    . ../../../install/setup.bash
    . install/setup.bash

    echo "== v2: channel resolution (no --sched) picks the provider platform file =="
    {{play_launch}} check rt_demo bringup.launch.xml

    echo "== v2: --explain shows derived + override + default provenance =="
    {{play_launch}} check --sched launch/bringup.system.posix.yaml --explain rt_demo bringup.launch.xml

    echo "== v2: user overlay tweaks the provider's band/pin (overlay always wins) =="
    {{play_launch}} check --contracts contracts rt_demo bringup.launch.xml

    echo "== v2: chain-aware --explain shows points_to_cmd chain provenance (Phase 44.5) =="
    {{play_launch}} check --sched launch/bringup.system.posix.yaml --explain rt_demo bringup.launch.xml 2>&1 \
        | grep -F "derived(chain_aware: points_to_cmd" \
        || { echo "ERROR: expected chain_aware provenance for points_to_cmd in --explain output"; exit 1; }

    echo "== legacy bridge: system.toml (manual mapper) + sched =="
    {{play_launch}} check --sched system.toml rt_demo bringup.launch.xml
    echo "== legacy bridge: system.toml overridden by user overlay CONTRACT (not platform file — system.toml is passed explicitly) =="
    {{play_launch}} check --contracts contracts --sched system.toml rt_demo bringup.launch.xml

# Schema-coexistence demo: a Zephyr platform file resolves and parses via the
# same --target channel mechanism, but play_launch's built-in mappers only
# derive plans for `posix` today (RTOS derivation is nano-ros's job) — this
# is EXPECTED to fail at the derive step, not the parse step. See
# docs/guide/rt-scheduling.md's "per-target coexistence" note.
check-zephyr-stub:
    #!/usr/bin/env bash
    . /opt/ros/{{ros_distro}}/setup.bash
    . ../../../install/setup.bash
    . install/setup.bash
    {{play_launch}} check --target zephyr rt_demo bringup.launch.xml && \
        { echo "UNEXPECTED: check --target zephyr succeeded"; exit 1; } || \
        echo "expected failure: deadline_monotonic requires posix facts (file parsed fine; derive is posix-only today)"

# Launch with RT scheduling applied (warn mode: no root/setcap required) —
# explicit legacy system.toml (kept as the living bridge test).
run:
    #!/usr/bin/env bash
    set -e
    . /opt/ros/{{ros_distro}}/setup.bash
    . ../../../install/setup.bash
    . install/setup.bash
    {{play_launch}} launch rt_demo bringup.launch.xml \
        --sched system.toml --sched-apply warn

# Launch with RT scheduling applied via v2 channel resolution — no --sched
# flag at all: play_launch discovers launch/bringup.system.posix.yaml (the
# provider sidecar) and applies the rate_monotonic-derived + overridden plan.
run-derived:
    #!/usr/bin/env bash
    set -e
    . /opt/ros/{{ros_distro}}/setup.bash
    . ../../../install/setup.bash
    . install/setup.bash
    {{play_launch}} launch rt_demo bringup.launch.xml --sched-apply warn

# Clean generated files (build artifacts + logs), keep source
clean:
    #!/usr/bin/env bash
    set -e
    echo "Cleaning up..."
    rm -rf play_log record*.json model_rust.yaml model_python.yaml build install log
    echo "Cleanup complete"
