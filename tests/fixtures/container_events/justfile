# Container Events Test Suite

# Variables
ros_distro := env_var_or_default('ROS_DISTRO', 'humble')

# Show help
default:
    @just --list

# Dump with Rust parser (--format record: legacy record.json, this
# suite's parser-parity comparison shape)
dump-rust:
    #!/usr/bin/env bash
    set -e
    . /opt/ros/{{ros_distro}}/setup.bash
    . ../../../install/setup.bash
    play_launch dump --format record launch launch/container_events.launch.xml

# Dump with Python parser
dump-python:
    #!/usr/bin/env bash
    set -e
    . /opt/ros/{{ros_distro}}/setup.bash
    . ../../../install/setup.bash
    play_launch dump --format record launch --parser python launch/container_events.launch.xml

# Compare Rust vs Python parser output — record.json shape (legacy,
# dev/parser-parity escape hatch).
compare-dumps-record:
    #!/usr/bin/env bash
    set -e
    . /opt/ros/{{ros_distro}}/setup.bash
    . ../../../install/setup.bash
    echo "=== Rust parser ==="
    play_launch dump --output /tmp/container_events_rust.json --format record launch launch/container_events.launch.xml
    echo "=== Python parser ==="
    play_launch dump --output /tmp/container_events_python.json --format record launch --parser python launch/container_events.launch.xml
    echo "=== Diff ==="
    python3 ../../../scripts/compare_records.py /tmp/container_events_rust.json /tmp/container_events_python.json || true

# Compare Rust vs Python parser output — SystemModel shape (Phase 47.B1:
# the parser-parity gate now runs on the model, not record.json).
compare-dumps:
    #!/usr/bin/env bash
    set -e
    REPO_ROOT="$(cd ../../.. && pwd)"
    . /opt/ros/{{ros_distro}}/setup.bash
    . "$REPO_ROOT/install/setup.bash"
    # Phase 46.5/47.B1 — colcon-built binary + current worktree's
    # `python/` package ahead of PATH/PYTHONPATH so this never silently
    # runs a stale pip install (the `--parser python` stale-scope-path
    # guard fails loud on that instead).
    export PATH="$REPO_ROOT/install/play_launch/lib/play_launch:$PATH"
    export PYTHONPATH="$REPO_ROOT/python:$PYTHONPATH"

    echo "=== Rust parser ==="
    play_launch resolve --parser rust -o model_rust.yaml launch/container_events.launch.xml
    echo "=== Python parser ==="
    play_launch resolve --parser python -o model_python.yaml launch/container_events.launch.xml
    echo "=== Diff ==="
    python3 "$REPO_ROOT/scripts/compare_models.py" model_rust.yaml model_python.yaml

# Clean generated files
clean:
    #!/usr/bin/env bash
    set -e
    echo "Cleaning up..."
    rm -rf play_log record.json model_rust.yaml model_python.yaml
    echo "Cleanup complete"
